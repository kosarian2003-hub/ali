{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.12"
  },
  "steps": {
    "install": {
      "commands": [
        "pwd",
        "find . -maxdepth 4 -type f",
        "pip install -r backend/requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "python backend/app.py"
  }
}
