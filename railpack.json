{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.12"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install -r proj/backend/requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "python proj/backend/app.py"
  }
}
